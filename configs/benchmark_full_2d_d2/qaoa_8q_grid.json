    "n_ops": 1000,
    "weight_strategy": "frank_wolfe",
    "baseline": [
      "standalone",
      "data_only"
    ],
    "shots": 10000,
    "keep_models_for_diagnosis": true,
    "stop_on_reject": false,
    "rng_seed": 42,
    "turbo": 10,
    "sigma_heuristic": {
      "method": "fourier",
      "n_sigmas": 5
    }
  },
  "runs": [
