          "graph_seed": 42,
          "p_depth": 1,
          "param_seed": 42
        }
      },
      "plot": {
        "kind": "lorenz",
        "params": {
          "filename": "qaoa_8q_lorenz.pdf"
        }
      },
      "config": {
