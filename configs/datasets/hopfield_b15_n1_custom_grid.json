{
    "output": {
        "base_dir": "out",
        "suite_name": "hopfield_grid_b15_pmf"
    },
    "defaults": {
        "train_samples": 10000,
        "data_seed": 42,
        "n_samples": 400,
        "n_models": 8,
        "learning_rate": 0.01,
        "epochs_per_step": 250,
        "caching_level": "none",
        "init_baseline": "covariance",
        "init_later": "random",
        "lambda_schedule": {
            "type": "frank_wolfe",
            "gamma": 1.0,
            "tau": 1.0
        },
        "sigma_heuristic": {
            "method": "median",
            "sigma_factor": [
                0.35
            ]
        },
        "n_ops": 2000,
        "weight_strategy": "frank_wolfe",
        "baseline": "standalone",
        "shots": 10000,
        "acceptance_metric": "training_mmd",
        "skip_sampling": false,
        "final_eval_sampling": true,
        "report_fcfw": true,
        "keep_models_for_diagnosis": true,
        "stop_on_reject": false,
        "rng_seed": 42,
        "turbo": 10,
        "sigma_holdout_fraction": 0.2
    },
