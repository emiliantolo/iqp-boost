{
  "output": {
    "base_dir": "out",
    "suite_name": "orig_blobs"
  },
  "runs": [
    {
      "name": "blobs",
      "dataset": {
        "name": "blobs"
      },
      "plot": {
        "kind": "sample_grid",
        "params": {
          "filename": "blobs_samples.png",
          "n_models_to_show": 3,
          "samples_per_model": 4
        }
      },
      "config": {
        "dims": [4, 4],
        "train_samples": 1000,
        "sigma_factor": [0.75],
        "n_ops": 1000,
        "n_samples": 2000,
        "n_models": 32,
        "learning_rate": 0.05,
        "epochs_per_step": 200,
        "caching_level": "none",
        "ensemble_samples_coeff": 1.0,
        "init_baseline": "covariance",
        "init_later": "random",
        "lambda_dual": 1.0,
        "weight_strategy": "line_search",
        "baseline": ["standalone", "data_only"],
        "shots": 1000,
        "keep_models_for_diagnosis": true,
        "stop_on_reject": false,
        "rng_seed": 42,
        "circuit_config": {
          "topology": "neighbour",
          "distance": 2,
          "max_weight": 2
        },
        "turbo": 10
      }
    }
  ]
}
