{
  "output": {
    "base_dir": "out",
    "suite_name": "graph_isomorphism"
  },
  "runs": [
    {
      "name": "graph_isomorphism_8n",
      "dataset": {
        "name": "graph_isomorphism",
        "params": {
          "num_nodes": 8,
          "edge_prob": 0.5,
          "train_split_ratio": 0.125,
          "seed": 42,
          "enforce_asymmetry": true
        }
      },
      "plot": {
        "kind": "none"
      },
      "config": {
        "train_samples": 5040,
        "data_seed": 42,
        "n_samples": 2000,
        "n_models": 2,
        "learning_rate": 0.01,
        "epochs_per_step": 20,
        "caching_level": "none",
        "ensemble_samples_coeff": 1.0,
        "init_baseline": "covariance",
        "init_later": "random",
        "lambda_dual": 1.0,
        "lambda_schedule": {
          "type": "frank_wolfe",
          "gamma": 1.0,
          "tau": 1.0
        },
        "sigma_heuristic": {
          "method": "fourier",
          "n_sigmas": 3
        },
        "n_ops": 2000,
        "weight_strategy": "frank_wolfe",
        "baseline": "standalone",
        "shots": 2000,
        "acceptance_metric": "training_mmd",
        "skip_sampling": true,
        "final_eval_sampling": true,
        "report_fcfw": false,
        "keep_models_for_diagnosis": false,
        "stop_on_reject": false,
        "rng_seed": 42,
        "circuit_config": {
          "topology": "neighbour",
          "distance": 1,
          "max_weight": 2
        },
        "turbo": 10
      }
    }
  ]
}
