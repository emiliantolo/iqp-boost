{
    "output": {
        "base_dir": "out",
        "suite_name": "qaoa_8q"
    },
    "runs": [
        {
            "name": "qaoa_8q",
            "dataset": {
                "name": "qaoa_maxcut",
                "params": {
                    "n_qubits": 8,
                    "graph_type": "random_regular",
                    "graph_seed": 42,
                    "p_depth": 1,
                    "param_seed": 42
                }
            },
            "plot": {
                "kind": "lorenz",
                "params": {
                    "filename": "qaoa_8q_lorenz.pdf"
                }
            },
            "config": {
                "train_samples": 2000,
                "data_seed": 42,
                "n_samples": 1000,
                "n_models": 10,
                "learning_rate": 0.05,
                "epochs_per_step": 400,
                "caching_level": "none",
                "init_baseline": "covariance",
                "init_later": "random",
                "lambda_schedule": {
                    "type": "frank_wolfe",
                    "gamma": 1.0,
                    "tau": 1.0
                },
                "sigma_factor": [
                    0.2,
                    0.3,
                    0.4,
                    0.6,
                    0.8
                ],
                "n_ops": 1000,
                "weight_strategy": "frank_wolfe",
                "baseline": "standalone",
                "shots": 1000,
                "keep_models_for_diagnosis": true,
                "stop_on_reject": false,
                "rng_seed": 42,
                "circuit_config": {
                    "topology": "neighbour",
                    "distance": 1,
                    "max_weight": 2,
                    "n_ancilla": 2
                },
                "turbo": 10
            }
        }
    ]
}